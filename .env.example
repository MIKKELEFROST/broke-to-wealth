# Kopiér til .env og udfyld. .env må ALDRIG committes (står i .gitignore).
# Gem også værdierne i en password manager — .env er bevidst uden for både git og backup.

# ElevenLabs — voiceover
ELEVENLABS_API_KEY=
# Kanalens faste brand-stemme (dyb mandlig). SKAL være samme stemme i hver video.
# Findes i ElevenLabs → My Voices → (stemmen) → ID. Er den væk: re-match/klon ud fra
# output/*/voiceover.mp3 (Voice Design / Instant Voice Cloning).
ELEVENLABS_VOICE_ID=

# Google Gemini — scene-billeder + thumbnail
GEMINI_API_KEY=

# OpenRouter — kun til Seedance video-eksperimenter (ikke kerne-pipelinen)
OPENROUTER_API_KEY=
